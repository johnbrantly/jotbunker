{
  "name": "jotbunker",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:shared": "vitest run --project shared",
    "test:mobile": "vitest run --project mobile",
    "test:desktop": "vitest run --project desktop",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
